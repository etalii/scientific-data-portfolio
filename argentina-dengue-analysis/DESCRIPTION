Package: argentinaDengueAnalysis
Title: Argentina Dengue Surveillance Analysis
Version: 0.1.0

Authors@R:
    person(
        "Andrés",
        "Lemos",
        email = "andlefa@gmail.com",
        role = c("aut", "cre")
    )

Description:
    Reproducible data science project for the acquisition,
    validation, processing, exploratory analysis and
    visualization of official dengue surveillance data
    published by the Argentine Ministry of Health.
    The project emphasizes reproducibility, transparent
    data provenance and good practices in statistical
    programming.

